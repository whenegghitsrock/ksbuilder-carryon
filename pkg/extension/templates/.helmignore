# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Development/build files (not needed at deploy time)
Makefile
.ksbuilder.yaml
# Source scaffolds - leading / excludes only root-level, not charts/frontend and charts/backend
/frontend/
/backend/